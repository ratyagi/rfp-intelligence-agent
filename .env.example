# Model provider: foundry (Azure/Microsoft Foundry deployment)
#                | github_models (GitHub Models free tier — zero cost, no Azure quota needed)
MODEL_PROVIDER=foundry

# Microsoft Foundry (model inference) — used when MODEL_PROVIDER=foundry
AZURE_FOUNDRY_ENDPOINT=https://<your-project>.services.ai.azure.com
AZURE_FOUNDRY_API_KEY=<your-key>
FOUNDRY_MODEL_DEPLOYMENT=gpt-4o-mini

# GitHub Models — used when MODEL_PROVIDER=github_models
# Create a fine-grained PAT with the "Models: read" permission at
# https://github.com/settings/personal-access-tokens
GITHUB_MODELS_TOKEN=<your-github-pat>
GITHUB_MODELS_MODEL=openai/gpt-4o-mini

# Tokens-per-minute pacing budget (0 disables; GitHub Models free tier ≈ 8k)
FOUNDRY_TPM_BUDGET=1000

# Foundry IQ knowledge base (agentic retrieval, powered by Azure AI Search)
# Create with: python scripts/setup_foundry_iq.py
AZURE_SEARCH_ENDPOINT=https://<your-service>.search.windows.net
AZURE_SEARCH_API_KEY=<your-admin-key>
FOUNDRY_IQ_KNOWLEDGE_BASE=rfp-evidence

# Retrieval mode: foundry_iq (live demo) | local (BM25 over corpus/, no Azure needed)
RETRIEVAL_MODE=local

# Azure AI Document Intelligence (RFP PDF parsing)
DOC_INTELLIGENCE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com
DOC_INTELLIGENCE_KEY=<your-key>

# Output
OUTPUT_DIR=./output

# Development
STUB_MODE=true
