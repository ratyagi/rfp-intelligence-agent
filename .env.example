# Azure AI Foundry
AZURE_FOUNDRY_ENDPOINT=https://<your-project>.services.ai.azure.com
AZURE_FOUNDRY_API_KEY=<your-key>
FOUNDRY_MODEL_DEPLOYMENT=gpt-4o

# Azure AI Document Intelligence
DOC_INTELLIGENCE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com
DOC_INTELLIGENCE_KEY=<your-key>

# Microsoft Graph API (via Entra app registration)
AZURE_TENANT_ID=<your-tenant-id>
AZURE_CLIENT_ID=<your-client-id>
AZURE_CLIENT_SECRET=<your-client-secret>

# SharePoint
SHAREPOINT_SITE_ID=<your-site-id>
SHAREPOINT_OUTPUT_FOLDER=/RFP-Outputs

# Teams
TEAMS_WEBHOOK_URL=<incoming-webhook-url>
TEAMS_CHANNEL_ID=<your-channel-id>

# Output
OUTPUT_DIR=./output

# Development
STUB_MODE=true
